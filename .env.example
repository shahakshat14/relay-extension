# Supabase
SUPABASE_PROJECT_REF=your-project-ref
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Stripe / Supabase Edge Function secrets
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret
STRIPE_PRICE_ID=your-stripe-price-id
SITE_URL=https://tridentcx.github.io/relay-extension

# Admin Edge Function
# Store only the SHA-256 hash in Supabase secrets, never the plaintext password.
ADMIN_PASSWORD_HASH=sha256-hex-admin-password
